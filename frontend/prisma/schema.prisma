datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Dietitian {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  questions Question[]
  createdAt    DateTime      @default(now())
  // 🌟 ADD THIS LINE: Track if the professional is verified
  isVerified   Boolean       @default(false)
  clients      Client[]
  appointments Appointment[]
  reviews      Review[]
  bookingRequests BookingRequest[]
}

model Client {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  dietitianId  String
  questions Question[]
  dietitian    Dietitian     @relation(fields: [dietitianId], references: [id], onDelete: Cascade)
  // 🌟 ADD THIS LINE: Track if the client is verified/activated
  isVerified   Boolean       @default(false)
  appointments Appointment[]
  mealPlans    MealPlan[]
  reviews      Review[]
  createdAt    DateTime      @default(now())
  weight       Float?   // <--- Make sure this exists and has the '?' for optional
  targetWeight Float?   // <--- Make sure this exists and has the '?' for optional
}

model Appointment {
  id          String   @id @default(cuid())
  dateTime    DateTime
  status      String   @default("PENDING")
  dietitianId String
  dietitian   Dietitian @relation(fields: [dietitianId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model MealPlan {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
model Question {
  id           String    @id @default(cuid())
  question     String    @db.Text
  answer       String?   @db.Text
  isPublic     Boolean   @default(false)
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dietitianId  String
  dietitian    Dietitian @relation(fields: [dietitianId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  answeredAt   DateTime?
}

model Review {
  id          String    @id @default(cuid())
  rating      Int
  comment     String?
  dietitianId String
  dietitian   Dietitian @relation(fields: [dietitianId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model BookingRequest {
  id             String      @id @default(cuid())
  name           String
  email          String
  preferredDate  String
  preferredTime  String
  message        String?
  status         String      @default("PENDING")
  dietitianId    String?
  dietitian      Dietitian?  @relation(fields: [dietitianId], references: [id])
  createdAt      DateTime    @default(now())
}